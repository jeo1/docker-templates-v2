{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prHourlyLimit": 0,
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "docker-compose"
  ],
  "commitMessageSuffix": "[{{depName}}]",
  "packageRules": [
    {
      "automergeType": "pr",
      "automerge": true,
      "baseBranches": [
        "main"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "nginx"
      ],
      "allowedVersions": "<=1.24"
    },
    {
      "automergeType": "pr",
      "automerge": true,
      "baseBranches": [
        "main"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker.gitea.com/gitea",
        "grafana/grafana",
        "louislam/uptime-kuma",
        "lscr.io/linuxserver/jackett",
        "lscr.io/linuxserver/jellyfin",
        "lscr.io/linuxserver/radarr",
        "lscr.io/linuxserver/sonarr",
        "portainer/portainer-ce",
        "quay.io/prometheus/node-exporter"
      ]
    }
  ]
}