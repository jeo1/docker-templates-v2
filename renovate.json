{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prHourlyLimit": 0,
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "docker-compose"
  ],
  "commitMessageSuffix": "[{{depName}}]",
  "packageRules": [
    {
      "automergeType": "pr",
      "automerge": true,
      "baseBranches": [
        "main"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "nginx"
      ],
      "allowedVersions": "<=1.18"
    },
    {
      "automergeType": "pr",
      "automerge": true,
      "baseBranches": [
        "main"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker.gitea.com/gitea",
        "grafana/grafana",
        "lscr.io/linuxserver/jackett",
        "lscr.io/linuxserver/sonarr"
      ]
    }
  ]
}